# Unraid 通常使用 nobody:users，即 99:100。
PUID=99
PGID=100
TZ=Asia/Shanghai
APP_PORT=8080

# 改成独立的长随机值；不要复用管理员密码。
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# 局域网直接用 HTTP 时为 false；通过 HTTPS 反向代理公网访问时必须为 true。
COOKIE_SECURE=false
# 仅在反向代理地址可信时填写，例如 Docker 网段 172.18.0.0/16；留空会忽略 X-Forwarded-For。
TRUSTED_PROXY_CIDR=

# Unraid 推荐改为 /mnt/user/appdata/peufmreader。
PEUFM_DATA_ROOT=./data
MAX_UPLOAD_BYTES=524288000
SESSION_TTL=720h

# 可选：将 PDF/EPUB 放入该目录的 inbox 子目录，稳定后会自动排队导入。
# 成功文件移到 processed，连续失败文件移到 failed 并附带错误说明。
PEUFM_IMPORT_ROOT=./data/import
IMPORT_SCAN_INTERVAL=10s
IMPORT_STABLE_AGE=10s

# scripts/backup.sh 的快照输出目录。
PEUFM_BACKUP_ROOT=./backups

# 可选：现有 Calibre 书库根目录。容器只读挂载，迁移时复制到应用书库。
# Unraid 示例：/mnt/user/ebooks/Calibre Library
CALIBRE_LIBRARY_PATH=./data/calibre

# 外部书目源会在首次启动时由这些变量初始化；之后在管理后台保存的设置优先。
# 只有管理员启用“导入后自动查询建议”时，导入任务才会自动调用对应服务。
BIBLIOGRAPHY_PROVIDERS=openlibrary
OPEN_LIBRARY_BASE_URL=https://openlibrary.org
BIBLIOGRAPHY_TIMEOUT=12s
# 管理后台会持久化后续修改；该变量只用于初始化新安装。
# DOUBAN_API_BASE_URL=http://192.168.3.118:5890
# 同时启用 Google Books 时改为 openlibrary,google-books 并填写 API Key。
# GOOGLE_BOOKS_API_KEY=replace-with-google-books-api-key

# PDF 首页封面与文本提取。auto 仅对扫描件运行 OCR；disabled 仍生成封面并尝试原生文本。
PDF_OCR_MODE=auto
PDF_OCR_LANGUAGES=chi_sim+eng
PDF_OCR_MAX_PAGES=500
PDF_OCR_DPI=180

# MOBI/AZW3 会保留原文件，并通过 libmobi 生成 EPUB 阅读缓存。DRM 文件不支持转换。
MOBI_CONVERTER_BIN=mobitool
MOBI_CONVERSION_TIMEOUT=2m

# 可选 AI 分类。留空 AI_PROVIDER 即完全禁用，不影响规则分类和导入。
# Ollama 示例：
# AI_PROVIDER=ollama
# AI_BASE_URL=http://192.168.1.10:11434
# AI_MODEL=qwen3:8b
# OpenAI-compatible 云端示例（管理员需明确触发，元数据会发送到该服务）：
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.example.com
# AI_MODEL=provider-model-name
# AI_API_KEY=replace-with-provider-api-key
AI_PROVIDER=
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT=45s
